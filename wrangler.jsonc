{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "metin2-helper",
  "compatibility_date": "2026-05-06",
  "assets": {
    "directory": "./dist/metin2-helper/browser",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
